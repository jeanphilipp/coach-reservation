{% extends 'base.html.twig' %}

{% block title %}Admin - Réservations{% endblock %}

{% block body %}
    <h1>Réservations en attente</h1>

    {% if pending is empty %}
        <p>Aucune réservation en attente.</p>
    {% else %}
        <table>
            <thead>
            <tr>
                <th>Date</th>
                <th>Heure</th>
                <th>Client</th>
                <th>Discipline</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for r in pending %}
                <tr>
                    <td>{{ r.sessionDate|date('Y-m-d') }}</td>
                    <td>{{ r.startHour }}h–{{ r.startHour + 1 }}h</td>
                    <td>{{ r.user.email }}</td>
                    <td>{{ r.discipline.name }}</td>
                    <td>{{ r.status }}</td>
                    <td>
                        <form method="post" action="{{ path('admin_reservations_accept', {id: r.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_reservation_' ~ r.id) }}">
                            <button type="submit">Accepter</button>
                        </form>

                        <form method="post" action="{{ path('admin_reservations_refuse', {id: r.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_reservation_' ~ r.id) }}">
                            <button type="submit">Refuser</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
