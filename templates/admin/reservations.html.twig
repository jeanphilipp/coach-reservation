{% extends 'base.html.twig' %}

{% block title %}Admin - Réservations{% endblock %}

{% block body %}
    <div class="container-xl">
        <div class="row justify-content-center mt-4">
            <div class="col-12 col-lg-10">

                <div class="card">
                    <div class="card-header">
                        <h1 class="card-title mb-0">Réservations en attente</h1>
                    </div>

                    <div class="card-body">
                        {% if pending is empty %}
                            <div class="text-secondary">Aucune réservation en attente.</div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-vcenter">
                                    <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Heure</th>
                                        <th>Client</th>
                                        <th>Discipline</th>
                                        <th>Statut</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for r in pending %}
                                        <tr>
                                            <td>{{ r.sessionDate|date('d/m/Y') }}</td>
                                            <td>{{ r.startHour }}h–{{ r.startHour + 1 }}h</td>
                                            <td>{{ r.user.email }}</td>
                                            <td>{{ r.discipline.name }}</td>
                                            <td>
                                                <span class="badge bg-yellow-lt">{{ r.status }}</span>
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-list flex-nowrap justify-content-end">
                                                    <form method="post" action="{{ path('admin_reservations_accept', {id: r.id}) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_reservation_' ~ r.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-success">
                                                            Accepter
                                                        </button>
                                                    </form>

                                                    <form method="post" action="{{ path('admin_reservations_refuse', {id: r.id}) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_reservation_' ~ r.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            Refuser
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>

                </div>

            </div>
        </div>
    </div>
{% endblock %}
