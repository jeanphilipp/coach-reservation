{% extends 'base.html.twig' %}

{% block title %}Nouvelle réservation{% endblock %}

{% block body %}
    <div class="container-xl py-4">
        <div class="row justify-content-center">
            <div class="col-12 col-md-9 col-lg-6">

                <div class="card card-md">
                    <div class="card-body">

                        <h1 class="card-title mb-3">Confirmer la réservation</h1>

                        <div class="mb-4">
                            <div class="text-secondary">Date</div>
                            <div class="fw-bold">{{ date|format_date('full', locale='fr')|capitalize }}</div>
                        </div>

                        <div class="mb-4">
                            <div class="text-secondary">Heure</div>
                            <div class="fw-bold">{{ hour }}h – {{ hour + 1 }}h</div>
                        </div>

                        <form method="post">
                            <div class="mb-3">
                                <label for="discipline" class="form-label">Discipline</label>
                                <select name="discipline_id" id="discipline" class="form-select" required>
                                    <option value="" selected disabled>Choisir une discipline</option>
                                    {% for discipline in disciplines %}
                                        <option value="{{ discipline.id }}">{{ discipline.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    Confirmer
                                </button>

                                <a href="{{ path('app_planning') }}" class="btn btn-outline-secondary">
                                    Retour
                                </a>
                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
