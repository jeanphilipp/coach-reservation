{% extends 'base.html.twig' %}

{% block title %}Planning{% endblock %}

{% block body %}
    <div class="container-xl py-4">

        <div class="text-center mb-3">
            <h1 class="h2 mb-1">Planning (lundi → vendredi)</h1>
            <div class="text-secondary">
                Semaine du {{ days[0]|date('d/m/Y') }} au {{ days[4]|date('d/m/Y') }}
            </div>
        </div>

        {# Navigation semaines #}
        <div class="d-flex justify-content-between align-items-center mb-3">
            <a class="btn btn-outline-secondary btn-sm"
               href="{{ path('app_planning', {week: weekOffset - 1}) }}">
                ← Semaine précédente
            </a>

            <a class="btn btn-outline-secondary btn-sm"
               href="{{ path('app_planning', {week: 0}) }}">
                Semaine courante
            </a>

            <a class="btn btn-outline-secondary btn-sm"
               href="{{ path('app_planning', {week: weekOffset + 1}) }}">
                Semaine suivante →
            </a>
        </div>

        <div class="card">
            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-vcenter table-bordered">
                        <thead>
                        <tr>
                            <th style="width: 12%">Heure</th>
                            {% for day in days %}
                                <th class="text-center" style="width: 16%">
                                    {{ day|date('D d/m') }}
                                </th>
                            {% endfor %}
                        </tr>
                        </thead>

                        <tbody>
                        {% for hour in hours %}
                            <tr>
                                <td><strong>{{ hour }}h – {{ hour + 1 }}h</strong></td>

                                {% for day in days %}
                                    {% set dateKey = day|date('Y-m-d') %}
                                    {% set isBooked = booked[dateKey][hour] is defined %}

                                    <td class="text-center">
                                        {% if isBooked %}
                                            <span class="badge bg-danger text-white fw-bold">Indisponible</span>
                                        {% else %}
                                            <a href="{{ path('app_reservation_new', {date: dateKey, hour: hour}) }}"
                                               class="btn btn-primary btn-sm">
                                                Réserver
                                            </a>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
{% endblock %}
