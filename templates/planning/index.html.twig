{% extends 'base.html.twig' %}

{% block title %}Planning{% endblock %}

{% block body %}
    <div class="container-xl py-3 py-md-5">

        <div class="row justify-content-center mb-3 mb-md-4">
            <div class="col-12 col-xl-10">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3 p-md-5 text-center">

                        <span class="badge bg-primary-lt text-primary mb-3 px-3 py-2">
                            Planning hebdomadaire
                        </span>

                        <h1 class="h2 h1-md fw-bold mb-2">
                            Réservez votre créneau sportif
                        </h1>

                        <p class="text-secondary mb-0 small small-md">
                            Semaine du
                            <strong>{{ days[0]|format_datetime(pattern='dd/MM/yyyy') }}</strong>
                            au
                            <strong>{{ days[4]|format_datetime(pattern='dd/MM/yyyy') }}</strong>
                        </p>

                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center mb-3 mb-md-4">
            <div class="col-12 col-xl-10">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3 p-md-4">
                        <div class="row g-2 justify-content-md-center">
                            <div class="col-12 col-md-3">
                                {% if weekOffset > 0 %}
                                    <a class="btn btn-outline-secondary w-100"
                                       href="{{ path('app_planning', {week: weekOffset - 1}) }}">
                                        ← Semaine précédente
                                    </a>
                                {% endif %}
                            </div>

                            <div class="col-12 col-md-3">
                                <a class="btn {{ weekOffset == 0 ? 'btn-primary' : 'btn-outline-primary' }} w-100"
                                   href="{{ path('app_planning', {week: 0}) }}">
                                    Revenir à la semaine courante
                                </a>
                            </div>

                            <div class="col-12 col-md-3">
                                <a class="btn btn-outline-secondary w-100"
                                   href="{{ path('app_planning', {week: weekOffset + 1}) }}">
                                    Semaine suivante →
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Vue desktop / tablette #}
        <div class="row justify-content-center d-none d-md-flex">
            <div class="col-12 col-xl-10">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                        <h2 class="h4 mb-1">Créneaux disponibles</h2>
                        <p class="text-secondary mb-0">
                            Sélectionnez un créneau libre pour effectuer une réservation.
                        </p>
                    </div>

                    <div class="card-body p-3 p-md-4">
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle text-center mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th class="fw-bold text-dark" style="width: 12%">Heure</th>
                                    {% for day in days %}
                                        <th class="text-center py-3" style="width: 16%">
                                            <div class="h3 mb-1">
                                                {{ day|format_datetime(pattern='EEEE')|capitalize }}
                                            </div>
                                            <div class="text-secondary fw-medium">
                                                {{ day|format_datetime(pattern='dd/MM') }}
                                            </div>
                                        </th>
                                    {% endfor %}
                                </tr>
                                </thead>

                                <tbody>
                                {% for hour in hours %}
                                    <tr>
                                        <td class="fw-semibold bg-light text-dark">
                                            {{ hour }}h - {{ hour + 1 }}h
                                        </td>

                                        {% for day in days %}
                                            {% set dateKey = day|date('Y-m-d') %}
                                            {% set isBooked = booked[dateKey][hour] is defined %}

                                            <td>
                                                {% if isBooked %}
                                                    <span class="badge bg-danger-lt text-danger px-3 py-2">
                                                        Indisponible
                                                    </span>
                                                {% else %}
                                                    <a href="{{ path('app_reservation_new', {date: dateKey, hour: hour}) }}"
                                                       class="btn btn-primary btn-sm px-3">
                                                        Réserver
                                                    </a>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Vue smartphone #}
        <div class="row justify-content-center d-md-none">
            <div class="col-12 col-xl-10">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 pt-4 px-3 pb-0">
                        <h2 class="h4 mb-1">Créneaux disponibles</h2>
                        <p class="text-secondary mb-0">
                            Sélectionnez un créneau libre pour effectuer une réservation.
                        </p>
                    </div>

                    <div class="card-body p-3">
                        {% for day in days %}
                            {% set dateKey = day|date('Y-m-d') %}

                            <div class="card mb-3 border">
                                <div class="card-body p-3">
                                    <div class="mb-3 text-center">
                                        <div class="h3 mb-1">
                                            {{ day|format_datetime(pattern='EEEE')|capitalize }}
                                        </div>
                                        <div class="text-secondary fw-medium">
                                            {{ day|format_datetime(pattern='dd/MM/yyyy') }}
                                        </div>
                                    </div>

                                    <div class="d-flex flex-column gap-2">
                                        {% for hour in hours %}
                                            {% set isBooked = booked[dateKey][hour] is defined %}

                                            <div class="d-flex justify-content-between align-items-center border rounded p-2 gap-2">
                                                <div class="fw-semibold">
                                                    {{ hour }}h - {{ hour + 1 }}h
                                                </div>

                                                <div class="text-end">
                                                    {% if isBooked %}
                                                        <span class="badge bg-danger-lt text-danger">
                                                            Indisponible
                                                        </span>
                                                    {% else %}
                                                        <a href="{{ path('app_reservation_new', {date: dateKey, hour: hour}) }}"
                                                           class="btn btn-primary btn-sm">
                                                            Réserver
                                                        </a>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
