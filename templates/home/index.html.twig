{% extends 'base.html.twig' %}

{% block title %}Coach Sportif - John Doe{% endblock %}

{% block body %}
    <div class="container-xl">
        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-11 col-lg-10">

                <div class="card card-md shadow-sm border-0">
                    <div class="card-body">

                        {# Header avec profil #}
                        <div class="row align-items-center mb-5">
                            <div class="col-auto">
                                <span class="avatar avatar-xl rounded bg-primary-lt">JD</span>
                            </div>
                            <div class="col">
                                <h1 class="h1 mb-1">John Doe</h1>
                                <div class="text-secondary fs-3">
                                    Coach sportif • Sports de combat • Lyon
                                </div>
                            </div>
                            <div class="col-12 col-md-auto mt-3 mt-md-0">
                                <a class="btn btn-primary btn-pill px-4 shadow-sm" href="{{ path('app_planning') }}">
                                    Voir le planning
                                </a>
                            </div>
                        </div>

                        {# Section présentation #}
                        <div class="row g-4 mb-5">
                            <div class="col-12 col-lg-8">
                                <h2 class="h2 mb-3">À propos</h2>
                                <p class="lead">
                                    Lyonnais passionné d’arts martiaux depuis l’enfance, je pratique la
                                    <strong>Boxe anglaise</strong>, le <strong>MMA</strong> et le
                                    <strong>Krav Maga</strong>.
                                </p>
                                <p class="text-secondary">
                                    Instructeur certifié de Krav Maga depuis 2017, je propose des <strong>cours privés</strong> sur mesure à Lyon, du
                                    <strong>lundi au vendredi</strong> entre <strong>17h et 21h</strong>. Mon approche se veut pragmatique et adaptée à vos objectifs.
                                </p>
                                <div class="mt-4 d-flex gap-2">
                                    <span class="badge bg-blue-lt px-3 py-2">Krav Maga</span>
                                    <span class="badge bg-red-lt px-3 py-2">Boxe</span>
                                    <span class="badge bg-green-lt px-3 py-2">MMA</span>
                                </div>
                            </div>
                            <div class="col-12 col-lg-4 d-none d-lg-block">
                                <div class="card bg-muted-lt border-0 h-100">
                                    <div class="card-body d-flex flex-column justify-content-center">
                                        <div class="mb-3">
                                            <div class="fw-bold mb-1">Localisation</div>
                                            <div class="text-secondary small">Lyon & alentours</div>
                                        </div>
                                        <div>
                                            <div class="fw-bold mb-1">Disponibilités</div>
                                            <div class="text-secondary small">Lun - Ven : 17h - 21h</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h2 class="h2 mb-4">Mes spécialités</h2>
                        <div class="row g-4 mb-4">
                            <div class="col-12 col-sm-4">
                                <div class="card h-100 card-sm shadow-none border overflow-hidden">
                                    <div class="ratio ratio-16x9">
                                        <img src="{{ asset('images/cours-kravmaga.jpg') }}" class="card-img-top object-cover" alt="Cours de Krav Maga">
                                    </div>
                                    <div class="card-body">
                                        <h3 class="card-title mb-2 text-primary">Krav Maga</h3>
                                        <p class="text-secondary small mb-0">
                                            Méthode d’autodéfense réaliste et accessible, le Krav Maga enseigne des techniques simples et efficaces pour se protéger rapidement en situation réelle.
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="card h-100 card-sm shadow-none border overflow-hidden">
                                    <div class="ratio ratio-16x9">
                                        <img src="{{ asset('images/cours-boxe.jpg') }}" class="card-img-top object-cover" alt="Cours de Boxe">
                                    </div>
                                    <div class="card-body">
                                        <h3 class="card-title mb-2 text-primary">Boxe anglaise</h3>
                                        <p class="text-secondary small mb-0">
                                            Sport de précision et de rythme, la boxe anglaise développe la technique, la vitesse et la condition physique grâce au travail des coups de poing et du déplacement.
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="card h-100 card-sm shadow-none border overflow-hidden">
                                    <div class="ratio ratio-16x9">
                                        <img src="{{ asset('images/cours-mma.png') }}" class="card-img-top object-cover" alt="Cours de MMA">
                                    </div>
                                    <div class="card-body">
                                        <h3 class="card-title mb-2 text-primary">MMA</h3>
                                        <p class="text-secondary small mb-0">
                                            Discipline complète combinant boxe, lutte et techniques au sol, le MMA offre un entraînement polyvalent et dynamique pour progresser dans tous les aspects du combat.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="hr-text text-secondary mt-5 fst-italic">Site fictif réalisé dans le cadre du titre CDA (Symfony 8)</div>

                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
